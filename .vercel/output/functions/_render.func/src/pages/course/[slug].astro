---
import { getCollection, getEntry, render } from 'astro:content';
import CourseLayout from '../../layouts/CourseLayout.astro';
import ProgressBtn from '../../components/ProgressBtn.astro';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/course/dashboard');

const lesson = await getEntry('course', slug);
if (!lesson) return Astro.redirect('/404');

const { Content } = await render(lesson);
---

<CourseLayout title={lesson.data.title} description={lesson.data.description}>
  <div class="lesson-content">
    <div class="lesson-header">
      <span class="lesson-tag">Module: {lesson.data.module}</span>
      <h1>{lesson.data.title}</h1>
    </div>

    {lesson.data.videoUrl && (
      <div class="video-container">
        <iframe 
          src={lesson.data.videoUrl} 
          frameborder="0" 
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
          allowfullscreen
        ></iframe>
      </div>
    )}

    <div class="prose">
      <Content />
    </div>

    <ProgressBtn lessonId={lesson.id} />

    <div class="lesson-footer">
      <hr />
      <p>Having trouble? <a href="/contact">Contact Support</a></p>
    </div>
  </div>
</CourseLayout>

<style>
  .lesson-header {
    margin-bottom: 2rem;
  }

  .lesson-tag {
    background: var(--color-primary);
    color: white;
    padding: 0.2rem 0.6rem;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    border-radius: 3px;
    margin-bottom: 0.5rem;
    display: inline-block;
  }

  .prose {
    font-size: 1.1rem;
    line-height: 1.8;
  }

  .prose :global(h2) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .video-container {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
    overflow: hidden;
    margin-bottom: 2rem;
    border-radius: 8px;
    background: #000;
  }

  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }

  .lesson-footer {
    margin-top: 3rem;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .lesson-footer hr {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin-bottom: 1.5rem;
  }
</style>

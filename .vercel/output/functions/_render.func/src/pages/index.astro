---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';

const posts = [
  {
    title: 'Hello World: Welcome to My New Site',
    date: 'March 13, 2026',
    excerpt: 'Welcome to your brand new website. This is your first post. Edit or delete it, then start writing!',
    author: 'Admin',
    image: 'https://images.unsplash.com/photo-1499750310107-5fef28a66643?auto=format&fit=crop&w=800&q=80'
  }
];

const features = [
  { title: 'Step-by-Step Lessons', desc: 'Over 20+ modules taking you from beginner to expert.' },
  { title: 'Lifetime Access', desc: 'One-time payment. No subscriptions. Access forever.' },
  { title: 'Community Support', desc: 'Access to our private Discord for help.' },
];
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="hero card">
    <div class="hero-content">
      <h1 id="hero-title">Master Modern Web Design with PremiumPress</h1>
      <p id="hero-sub" class="hero-sub">The ultimate course for building high-performance, WordPress-style sites with Astro and Netlify.</p>
      <div class="hero-actions">
        <a id="hero-primary" href="#pricing" class="btn btn-primary">Join the Course</a>
        <a href="/course/dashboard" class="btn btn-secondary">Go to Dashboard</a>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="features">
    {features.map(f => (
      <div class="feature card">
        <h3>{f.title}</h3>
        <p>{f.desc}</p>
      </div>
    ))}
  </section>

	<div class="site-layout">
		<section class="main-content">
      <h2 class="section-title">Latest from the Blog</h2>
			{posts.map(post => (
				<article class="post-preview card">
          <img src={post.image} alt={post.title} class="post-image" />
          <div class="post-meta">
            <span class="date">{post.date}</span> • <span class="author">By {post.author}</span>
          </div>
          <h2 class="post-title"><a href="#">{post.title}</a></h2>
          <p class="post-excerpt">{post.excerpt}</p>
          <a href="#" class="read-more">Read More &rarr;</a>
        </article>
			))}
		</section>
		<Sidebar />
	</div>

  <!-- Pricing -->
  <section id="pricing" class="pricing-section">
    <div class="pricing-card card featured">
      <div class="badge">Most Popular</div>
      <h2>Full Course Access</h2>
      <div class="price">$199<span class="currency">USD</span></div>
      <ul class="pricing-features">
        <li>All 50+ Modern Web Lessons</li>
        <li>Netlify & Astro Templates</li>
        <li>Stripe Integration Guide</li>
        <li>Private Community Discord</li>
      </ul>
      <button id="checkout-btn" class="btn btn-checkout">Purchase Now</button>
    </div>
  </section>
</Layout>

<script>
  // Handle Auth State on Homepage
  document.addEventListener('DOMContentLoaded', () => {
    // @ts-ignore
    const identity = window.netlifyIdentity;
    if (!identity) return;

    const heroTitle = document.getElementById('hero-title');
    const heroSub = document.getElementById('hero-sub');
    const heroPrimary = document.getElementById('hero-primary');

    function updateHero() {
      const user = identity.currentUser();
      if (user && heroTitle && heroSub && heroPrimary) {
        heroTitle.innerText = "Welcome Back, Student!";
        heroSub.innerText = "Ready to continue your journey? Dive back into your lessons below.";
        heroPrimary.innerText = "Resume Course";
        heroPrimary.setAttribute('href', '/course/dashboard');
      }
    }

    identity.on('init', updateHero);
    identity.on('login', updateHero);
  });

  // Mock Checkout flow
  const checkoutBtn = document.getElementById('checkout-btn');
  if (checkoutBtn) {
    checkoutBtn.addEventListener('click', () => {
      // @ts-ignore
      const identity = window.netlifyIdentity;
      if (!identity) return;

      const user = identity.currentUser();
      if (!user) {
        alert('Please log in or sign up first to purchase.');
        identity.open('signup');
      } else {
        // In a real app, you'd redirect to Stripe Checkout here
        window.location.href = '/success';
      }
    });
  }
</script>

<style>
  .hero {
    padding: 6rem 2rem;
    text-align: center;
    background: linear-gradient(135deg, #f0f7ff 0%, #ffffff 100%);
    margin-top: 2rem;
  }

  .hero h1 {
    font-size: 3.5rem;
    margin-bottom: 1.5rem;
    line-height: 1.1;
  }

  .hero-sub {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    max-width: 700px;
    margin: 0 auto 2.5rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .btn {
    padding: 0.8rem 1.8rem;
    font-weight: 700;
    border-radius: 4px;
    font-size: 1rem;
    cursor: pointer;
    border: none;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background: var(--color-primary);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-primary-hover);
    transform: translateY(-2px);
  }

  .btn-secondary {
    background: white;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
  }

  .btn-secondary:hover {
    background: #f0f7ff;
  }

  .features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  .feature h3 {
    font-size: 1.25rem;
    margin-bottom: 0.8rem;
    color: var(--color-primary);
  }

  .section-title {
    margin-bottom: 2rem;
    font-size: 2rem;
  }

  .post-preview {
    margin-bottom: 3rem;
  }

  .post-image {
    width: 100%;
    height: 300px;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 1.5rem;
  }

  .pricing-section {
    padding: 6rem 0;
    display: flex;
    justify-content: center;
  }

  .pricing-card {
    max-width: 450px;
    width: 100%;
    text-align: center;
    padding: 4rem 2rem;
    position: relative;
    border: 2px solid var(--color-primary);
  }

  .pricing-card.featured {
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
  }

  .badge {
    position: absolute;
    top: -15px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: white;
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-weight: 700;
    font-size: 0.8rem;
    text-transform: uppercase;
  }

  .price {
    font-size: 4rem;
    font-weight: 800;
    margin: 1.5rem 0;
    font-family: var(--font-heading);
  }

  .currency {
    font-size: 1rem;
    color: var(--color-text-muted);
    font-weight: 400;
    margin-left: 0.5rem;
  }

  .pricing-features {
    list-style: none;
    margin: 2rem 0;
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .pricing-features li::before {
    content: "✓";
    color: var(--color-primary);
    font-weight: 900;
    margin-right: 0.8rem;
  }

  .btn-checkout {
    width: 100%;
    background: var(--color-primary);
    color: white;
    padding: 1rem;
    font-size: 1.1rem;
  }

  @media (max-width: 900px) {
    .features {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const lessons = (await getCollection('course')).sort((a, b) => a.data.order - b.data.order);
---

<Layout title="Course Dashboard">
  <div class="dashboard-header card">
    <h1>Welcome to Your Course</h1>
    <p>Track your progress and access all your lessons below.</p>
  </div>

  <div class="lesson-grid">
    {lessons.map(lesson => (
      <div 
        class="lesson-card card" 
        data-lesson-item 
        data-free={lesson.data.freePreview ? 'true' : 'false'}
      >
        <div class="lesson-num">{lesson.data.order}</div>
        <div class="lesson-info">
          <h3>{lesson.data.title}</h3>
          <p>{lesson.data.description}</p>
          <a href={`/course/${lesson.id}`} class="btn lesson-link">
            {lesson.data.freePreview ? 'Start Preview' : 'Access Lesson'}
          </a>
        </div>
      </div>
    ))}
  </div>

  <script>
    // Visual locking logic for non-logged in users
    document.addEventListener('DOMContentLoaded', () => {
      // @ts-ignore
      const identity = window.netlifyIdentity;
      if (!identity) return;

      const updateDashboardLock = () => {
        const user = identity.currentUser();
        const lessonCards = document.querySelectorAll('[data-lesson-item]');
        
        lessonCards.forEach(card => {
          const isFree = card.getAttribute('data-free') === 'true';
          if (!user && !isFree) {
            card.classList.add('locked');
            const link = card.querySelector('.lesson-link');
            if (link) {
              link.innerHTML = '🔒 Locked';
              // @ts-ignore
              link.style.pointerEvents = 'none';
            }
          } else {
            card.classList.remove('locked');
            const link = card.querySelector('.lesson-link');
            if (link) {
              link.innerHTML = isFree ? 'Start Preview' : 'Access Lesson';
              // @ts-ignore
              link.style.pointerEvents = 'auto';
            }
          }
        });
      };

      identity.on('init', updateDashboardLock);
      identity.on('login', updateDashboardLock);
      identity.on('logout', updateDashboardLock);
      
      // Initial check
      updateDashboardLock();
    });
  </script>
</Layout>

<style>
  .dashboard-header {
    text-align: center;
    padding: 4rem 2rem;
    margin-bottom: 3rem;
    background: linear-gradient(135deg, #f0f7ff 0%, #ffffff 100%);
  }

  .dashboard-header h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .lesson-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 2rem;
    margin-bottom: 5rem;
  }

  .lesson-card {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    transition: transform 0.2s ease;
  }

  .lesson-card:hover {
    transform: translateY(-5px);
  }

  .lesson-num {
    background: var(--color-primary);
    color: white;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-weight: 700;
    flex-shrink: 0;
  }

  .lesson-info h3 {
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
  }

  .lesson-info p {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .btn {
    display: inline-block;
    padding: 0.6rem 1.2rem;
    background: var(--color-primary);
    color: white;
    font-weight: 600;
    border-radius: 4px;
    font-size: 0.9rem;
  }

  .btn:hover {
    background: var(--color-primary-hover);
    color: white;
  }

  /* Locked State */
  .lesson-card.locked {
    opacity: 0.6;
    filter: grayscale(0.8);
    cursor: not-allowed;
    pointer-events: none;
    transform: none !important;
    box-shadow: none !important;
  }

  .lesson-card.locked .lesson-num {
    background: #ccc;
  }
</style>
